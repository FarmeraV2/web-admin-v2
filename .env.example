# Port for the web-admin dev/production server
PORT=3001

# Backend API base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# iron-session encryption secret — must be ≥32 chars, keep secret
# Generate with: openssl rand -base64 32
SESSION_SECRET=replace-with-a-strong-random-secret-at-least-32-chars

SEPOLIA_RPC_URL=replace-with-sepolia-rpc-url
